name: GUI Test Screenshots

on:
  pull_request:
    types: [opened, reopened, synchronize]
    branches: [main]

permissions:
  contents: write
  pull-requests: write

jobs:
  capture-and-comment:
    runs-on: ubuntu-latest
    timeout-minutes: 15
    
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Install Playwright
        run: npx playwright install chromium

      - name: Create screenshots directory
        run: mkdir -p screenshots

      - name: Run screenshot tests
        run: npx playwright test tests/gui-screenshots.spec.js

      - name: Upload screenshots to PR comment
        uses: opengisch/comment-pr-with-images@upload_only
        with:
          images: "screenshots/*.jpg"
          upload_to: "github_branch"
          github_token: ${{ secrets.GITHUB_TOKEN }}
          custom_attachment_msg: |
            ## 🖼️ Automated GUI Test Preview
            **Commit:** ${{ github.sha }}
            **Workflow:** [${{ github.workflow }} Run](${{ github.server_url }}/${{ github.repository }}/actions/runs/${{ github.run_id }})
            
            Below are the latest UI states captured by Playwright:
